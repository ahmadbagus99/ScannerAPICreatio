SCANNER_PORT=5002

# Root folder yang bisa di-browse dari UI (khusus Docker)
# Sesuaikan dengan OS host yang menjalankan Docker:
# Mac:     HOST_BROWSE_ROOT=/Users
# Linux:   HOST_BROWSE_ROOT=/home
# Windows: HOST_BROWSE_ROOT=C:/Users
# Catatan: tanpa Docker, BROWSE_ROOT di-set otomatis oleh start.ps1
HOST_BROWSE_ROOT=/Users

# ── Database ─────────────────────────────────────────────────────────────────
# Opsi A: pakai postgres container sendiri (default, tidak perlu set POSTGRES_HOST/PORT)
# Opsi B: pakai postgres yang sudah jalan (shared), uncomment dan isi bagian ini:
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=5433

POSTGRES_DB=creatio_scanner
POSTGRES_USER=creatio_user
POSTGRES_PASSWORD=change-this-db-password

